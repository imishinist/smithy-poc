{
  "version": "1.0",
  "sources": ["model"],
  "projections": {
    "openapi": {
      "plugins": {
        "openapi": {
          "service": "net.imishinist#MyService"
        }
      }
    },
    "proto": {
      "plugins": {
        "proto-gen": {
          "package": "net.imishinist",
          "options": {
            "go_package": "github.com/imishinist/smithy-poc/gen/proto"
          }
        }
      }
    },
    "validation": {
      "plugins": {
        "validation-rules": {}
      }
    }
  }
}
